<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1" ProductVersion="3.1.4024.15">
  <POU Name="fbMachine" Id="{9b5b41b1-bffa-4f3d-a529-a4397e82e585}" SpecialFunc="None">
    <Declaration><![CDATA[FUNCTION_BLOCK fbMachine EXTENDS FB_Generic
VAR_INPUT
END_VAR
	
VAR_OUTPUT
	SAuto_Token		:E_UnitName;
	SAuto_Task		:E_UnitTask;
END_VAR

VAR_IN_OUT
	
END_VAR

VAR
	
	fbBackGauge: fb_BackGauge;		
	fbApron: fb_Apron;
	fbClamp: fb_Clamp;
	fbSlitter: fb_Slitter;
	
	
	fbPumpA	:ANALOG_OUT;
	fbPumpB	:ANALOG_OUT;
	
	ton1,ton2,ton3,ton4	:TON;
	
	SemiAuto,SlitterAuto,Auto	:PML_UnitModeConfig;
	
	
	stSubModuleInfo		: ARRAY [1..4] OF ST_PMLSubUnitInfo;	//Informations about the Subunits
	iBootSeq: INT;
	iBootState: INT;
	ActType: INT;
	iSemiAutoJob: INT;
	
	
	
	iSemiAutoStp: INT;
	iSemiAuto_JobId: INT;
	
	iSlitterAutoStp: INT;
	SlitterAuto_rWidthOdd: REAL;
	SlitterAuto_rBGTarget: REAL;
	SlitterAuto_iPieceNum: INT;
	SlitterAuto_iJobId: INT;
	rtSlitterMode	:R_TRIG;
	Hmi_rSlitterAuto: INT;
	SlitterAuto_JobId: INT;
	SlitterAuto_rNextBackGauge: REAL;
	
	SA_Ton1	:TON;
	
	SA_s1: BOOL;
	SA_s2: BOOL;
	SA_Top_Target,SA_Btm_Target: REAL;
	
	Ton_DP0: Ton;
	Ton_DP1: TON;
	THEM: INT;
	override: REAL;
	rtOperatorSW 	:R_trig;
	
	ledtest1,ledtest2,ledtest3,ledtest4,ledtest5 	:BOOL;
	EMG_RopeStop	:BOOL;
	tonRope1,tonRope2	:TON;
	iRopeStep	 :INT;
	iPumpA_SetVal: REAL;
	iPumpB_SetVal: REAL;
	
	Ton_Fst5Min	:TON;
	SA_Ton2: Ton;
	iStpTemp: INT;
	ton372: Ton;
	angleAddit: REAL;
	i1: INT;
	iSemiCount: INT;

	rtPdlFold: R_trig;
	bSlitterHead: BOOL;
	_override: REAL;
	_PumpA_SetVal: REAL;
	_PumpB_SetVal: REAL;

	rtEnAuto	:R_TRIG;
	rtEnSemiAuto: R_trig;
	rtEnManual: R_trig;
	i111: INT;
	i112: INT;
	i114: INT;
	tonRopeStop: Ton;
	tmp1: REAL;
	inLoadRst: INPUT;
	ftLoadRst: f_trig;

	iAdd: INT := 0;
	tonArray60: Ton;
	aa: REAL;
	iWholeRst: INT;
	tmp2: INT;
	ton181: TON;
	TON162: Ton;
	_iHeavyGauge: INT;
	_ActBG_Target: REAL;
	tonSlipPatch_BtmSlide: Ton;
	tonSlipPatch_BtmFold: Ton;
	_bSlipPatch_BtmSlide: BOOL;
	_bSlipPatch_BtmFold: BOOL;
	tonSlipPatch_BtmSlidex: Ton;
	tonSlipPatch_BtmFoldx: Ton;
	rtSlipPatch_BtmSlide: R_trig;
	rtSlipPatch_BtmFold: R_trig;
	ftSlipPatch_BtmSlide,ftSlipPatch_BtmFold	:F_TRIG;
	tonUnClamp3s: TON;
	rtUnClamp3s: R_trig;
	i113: INT;
	_Contius: BOOL;
	rtLubePumpCount: R_trig;
	iLubePumpCount: INT;
	tonLubePump: Ton;
	_tmp0: REAL;
	bGripperDatumBack: BOOL;
	ton112: Ton;
	Tpr_T1: REAL;
	Tpr_T2,Tpr_T3,Tpr_T4: REAL;
	r1: REAL;
	r2: REAL;
	ton541: TON;
	bBtmSlide2: BOOL;
	r3: INT;

	tonGripper: Ton;
	ClampFeedHight: REAL;
	FeedDone: BOOL;
	FeedEnable: BOOL;
	iFeedAutoStep: INT;
	Feed_Target: REAL;
	tonFeed,tonFeed1,tonFeed2,tonFeed3,tonFeed4: Ton;
	TONDELAY: Ton;
	FeedDemoMode: BOOL;
	GRIP_AUTOOPEN_TIME: TIME;
	CNST_GRIP_AUTOOPEN_TIME: REAL;
	RemainingQuantity: INT;
	ton101: Ton;
	ParaMaxDeltaTpr: REAL;
	ParaMaxDeltaS: REAL;
	deltaS_T1, deltaS_T2, deltaS_T3, deltaS_T4:REAL;
	isInitialState: BOOL;
	Tpr_W: REAL;
	ton812,Ton813,ton822,Ton823,ton825: Ton;
	Tonagain: Ton;
	ton814: Ton;
END_VAR

VAR CONSTANT
	
END_VAR
]]></Declaration>
    <Implementation>
      <ST><![CDATA[SUPER^();
(* ********************* User Select ********************** *)
rtOperatorSW(CLK:=In_swOperator);
IF rtOperatorSW.Q THEN
	Operators := SEL(Operators >= 1,Operators + 1,1);
END_IF
pedal_UnClamp	:= (Operators<=1 AND In_pedal1_UnClamp);

pedal_Clamp		:=(Operators<=1 AND In_pedal1_Clamp);

pedal_Slitter	:=(Operators<=1 AND In_pedal1_Slitter);

pedal_SlitterBack	:=(Operators<=1 AND In_pedal1_SlitterBack);

pedal_Fold		:=In_pedal1_Fold;

pedal_Gripper 	:=(Operators<=1 AND In_pedal1_Gripper);

rtPdlFold(CLK:=In_pedal1_Fold , Q=> );
(* ************************************************** *)
IF Hmi_bArray[65] THEN
	iSemiCount	:=0;
END_IF
Hmi_iArray[62]	:=TO_UINT(iSemiCount);

tonArray60(IN:=Hmi_bArray[60] OR Hmi_bArray[80] , PT:=T#50MS);
IF tonArray60.Q THEN
	Hmi_bArray[60]	:= Hmi_bArray[80] :=FALSE;
END_IF

//gvl_rtEnSemiAuto(CLK:=Hmi_bArray[60] , Q=> );

gvl_rtEnSlitter(CLK:=Hmi_bArray[80] , Q=> );
gvl_rtEnManual(CLK:=fbUnitModeManager.eModeStatus=ePMLProtUnitMode_Manual , Q=> );

IF gvl_rtEnSemiAuto.Q THEN	
	i113	:=i113+1;
END_IF

bReset	:=Hmi_bArray[41];
rtReset(CLK:=bReset, Q=> );
IF rtReset.Q OR gvl_rtEnSemiAuto.Q OR gvl_rtEnSlitter.Q OR gvl_rtEnManual.Q THEN
	stFolderCom.TaskClamp		:=eTask_NULL;
	stFolderCom.TaskBackGauge	:=eTask_NULL;
	stFolderCom.TaskApron		:=eTask_NULL;
	stFolderCom.TaskSlitter		:=eTask_NULL;
	stFolderCom.TaskTable		:=eTask_NULL;
	stFolderCom.TaskFeed		:=eTask_NULL;
END_IF

stFolder.Status.FoldRunning	:=(fbUnitModeManager.eModeStatus=ePMLUnitMode_SemiAuto OR fbUnitModeManager.eModeStatus=ePMLUnitMode_Auto) 
								AND (iSemiAutoStp>=100);

fbApron(
	eModeCommand:=eModeCommand , 
	eCommand:= eCommand, 
	eMode=> , 
	eState=> , 
	bUndefinedDone=> , 
	bInvalidModeCommandOut=> , 
	bChangeIntoProduction=>   );
stSubModuleInfo[1].Active:=TRUE;
stSubModuleInfo[1].eState:=fbApron.eState;


fbBackGauge(
	eModeCommand:=eModeCommand , 
	eCommand:=eCommand , 
	eMode=> , 
	eState=> , 
	bUndefinedDone=> , 
	bInvalidModeCommandOut=> , 
	bChangeIntoProduction=> , 
	
	bReset:= , 
	bAxisEnable:=TRUE );
stSubModuleInfo[2].Active:=TRUE;
stSubModuleInfo[2].eState:=fbBackGauge.eState;
	
fbClamp(
	eModeCommand:=eModeCommand , 
	eCommand:=eCommand , 
	eMode=> , 
	eState=> , 
	bUndefinedDone=> , 
	bInvalidModeCommandOut=> , 
	bChangeIntoProduction=> );
stSubModuleInfo[3].Active:=TRUE;
stSubModuleInfo[3].eState:=fbApron.eState;

fbSlitter(
	eModeCommand:=eModeCommand , 
	eCommand:=eCommand , 
	eMode=> , 
	eState=> , 
	bUndefinedDone=> , 
	bInvalidModeCommandOut=> , 
	bChangeIntoProduction=> );
stSubModuleInfo[4].Active:=TRUE;
stSubModuleInfo[4].eState:=fbApron.eState;


DualPump();


//The fbStateMachine from FB_Machine gets the Information about the states and activity from the subunits
fbStateMachine.stSubUnitInfoRef.ArraySize		:= SIZEOF(stSubModuleInfo);
fbStateMachine.stSubUnitInfoRef.NoOfSubUnits	:= 4;
fbStateMachine.stSubUnitInfoRef.pArray			:= ADR(stSubModuleInfo);


//SUPER^();

M_SetUnitInfo();
	
Auto(
	eMode:= ePMLUnitMode_Auto, 
	sName:= 'Auto', 
	bDisableClearing:= , 
	bDisableStarting:= , 
	bDisableSuspended:= , 
	bDisableStopping:= , 
	bDisableAborting:= , 
	bDisableHolding:= , 
	bDisableHeld:= , 
	bDisableUnholding:= , 
	bDisableSuspending:= , 
	bDisableUnsuspending:= , 
	bDisableResetting:= , 
	bDisableIdle:= , 
	bDisableCompleting:= , 
	bDisableComplete:= , 
	bEnableUnitModeChangeStopped:= TRUE, 
	bEnableUnitModeChangeIdle:= , 
	bEnableUnitModeChangeSuspended:= , 
	bEnableUnitModeChangeExecute:= , 
	bEnableUnitModeChangeAborted:= TRUE, 
	bEnableUnitModeChangeHeld:= , 
	bEnableUnitModeChangeComplete:= , 
	bError=> , 
	nErrorId=> );
	
SemiAuto(
	eMode:=ePMLUnitMode_SemiAuto, 
	sName:='SemiAuto' , 
	bDisableClearing:= , 
	bDisableStarting:= , 
	bDisableSuspended:= , 
	bDisableStopping:= , 
	bDisableAborting:= , 
	bDisableHolding:= , 
	bDisableHeld:= , 
	bDisableUnholding:= , 
	bDisableSuspending:= , 
	bDisableUnsuspending:= , 
	bDisableResetting:= , 
	bDisableIdle:= , 
	bDisableCompleting:= , 
	bDisableComplete:= , 
	bEnableUnitModeChangeStopped:= TRUE , 
	bEnableUnitModeChangeIdle:= , 
	bEnableUnitModeChangeSuspended:= , 
	bEnableUnitModeChangeExecute:= , 
	bEnableUnitModeChangeAborted:=TRUE , 
	bEnableUnitModeChangeHeld:= , 
	bEnableUnitModeChangeComplete:= , 
	bError=> , 
	nErrorId=> );

SlitterAuto(
	eMode:=ePMLUnitMode_AutoSlitter , 
	sName:='AutoSlitter' , 
	bDisableClearing:= , 
	bDisableStarting:= , 
	bDisableSuspended:= , 
	bDisableStopping:= , 
	bDisableAborting:= , 
	bDisableHolding:= , 
	bDisableHeld:= , 
	bDisableUnholding:= , 
	bDisableSuspending:= , 
	bDisableUnsuspending:= , 
	bDisableResetting:= , 
	bDisableIdle:= , 
	bDisableCompleting:= , 
	bDisableComplete:= , 
	bEnableUnitModeChangeStopped:=TRUE , 
	bEnableUnitModeChangeIdle:= , 
	bEnableUnitModeChangeSuspended:= , 
	bEnableUnitModeChangeExecute:= , 
	bEnableUnitModeChangeAborted:=TRUE , 
	bEnableUnitModeChangeHeld:= , 
	bEnableUnitModeChangeComplete:= , 
	bError=> , 
	nErrorId=> );

HMI();
A_CNSTVar();


Out_OpLed_Red		:= NOT In_EMG_RopeStop;
Out_OpLed_Yellow	:= TRUE;
Out_OpLed_Green		:= In_pedal1_UnClamp OR In_pedal1_Clamp OR In_pedal1_Slitter OR In_pedal1_SlitterBack
				OR In_pedal1_Fold OR In_pedal1_Gripper;

Out_OpLed_Beep		:= ledtest4;

Out_Led_Red:= stFolder.ClampHt_ActPos < stFolderPara.ClampHalfPos;
Out_Led_Yellow :=NOT Out_Led_Red AND NOT Out_Led_Green;
Out_Led_Green :=stFolder.ClampHt_ActPos > 200 ;

//Out_LubePump	:=TRUE;
(*
-------------------------------------------EMG_RopeStop-----------------------------------------
*)
CASE iRopeStep OF
0:
	//iRopeStep	:=SEL(In_EMG_RopeStop,0,1);
1:
	Out_ClampUp		:=TRUE;
	Out_ClampDown	:=FALSE;
	iRopeStep	:=SEL(tonRope1.Q,1,2);
2:
//	Out_EMG_RopeStop	:=TRUE;
	Out_ClampUp		:=Out_ClampDown	:=FALSE;
	iRopeStep	:=SEL(tonRope2.Q,2,3);
3:
//	Out_EMG_RopeStop	:=FALSE;
END_CASE
tonRope1(IN:=Out_ClampUp , PT:=T#5S);
tonRope2(IN:=Out_EMG_RopeStop , PT:=T#2S);
(*------------------------------------------- LubePump Count -----------------------------------------*)
(*****************************所有阀累计工作3000次时，润滑泵工作10分钟*********************************)
rtLubePumpCount(CLK:=Out_PumpA_Load_Heav OR Out_PumpA_Load_Ligh OR Out_PumpB_Load_Heav OR Out_PumpB_Load_Ligh , Q=> );
IF rtLubePumpCount.Q THEN
	LubePumpCount	:=LubePumpCount+1;
END_IF
Out_LubePump	:=LubePumpCount>3000;	
tonLubePump(IN:=Out_LubePump , PT:=T#2M , Q=> , ET=> );
IF tonLubePump.Q THEN
	LubePumpCount:=0;
END_IF
//Out_LubePump	:=TRUE;	


aWarning();



]]></ST>
    </Implementation>
    <Action Name="A_CNSTVar" Id="{06e9865b-0aba-4153-bb8e-874c9105c0f2}">
      <Implementation>
        <ST><![CDATA[CNST_HYD_IDLE_SPD					:=AdvPara[0];
	
CNST_APRON_TOPSLIDE_FWD_SPD			:=AdvPara[2];
CNST_APRON_TOPSLIDE_FWD_CREEP_SPD	:=AdvPara[3];
CNST_APRON_TOPSLIDE_BWD_SPD			:=AdvPara[4];
CNST_APRON_TOPSLIDE_BWD_CREEP_SPD	:=AdvPara[5];
CNST_APRON_BTMSLIDE_FWD_SPD			:=AdvPara[6];
CNST_APRON_BTMSLIDE_FWD_CREEP_SPD	:=AdvPara[7];
CNST_APRON_BTMSLIDE_BWD_SPD			:=AdvPara[8];
CNST_APRON_BTMSLIDE_BWD_CREEP_SPD	:=AdvPara[9];
CNST_APRON_TOPSLIDE_FWD_DecDis		:=AdvPara[10];
CNST_APRON_TOPSLIDE_BWD_DecDis		:=AdvPara[11];
CNST_APRON_BTMSLIDE_FWD_DecDis		:=AdvPara[12];
CNST_APRON_BTMSLIDE_BWD_DecDis		:=AdvPara[13];
CNST_APRON_SLIDE_WINDOWS			:=AdvPara[14];
CNST_APRON_TOPSLIDE_POS0			:=AdvPara[15];
CNST_APRON_TOPSLIDE_POS1			:=AdvPara[16];
CNST_APRON_TOPSLIDE_POS2			:=AdvPara[17];
CNST_APRON_TOPSLIDE_POS3			:=AdvPara[18];
CNST_APRON_BTMSLIDE_POS0			:=AdvPara[19];
CNST_APRON_BTMSLIDE_POS1			:=AdvPara[20];
CNST_APRON_BTMSLIDE_POS2			:=AdvPara[21];
CNST_APRON_BTMSLIDE_POS3			:=AdvPara[22];
	
CNST_APRON_TOPFOLD_FWD_SPD			:=AdvPara[24];
CNST_APRON_TOPFOLD_FWD_CREEP_SPD	:=AdvPara[25];
CNST_APRON_TOPFOLD_BWD_SPD			:=AdvPara[26];
CNST_APRON_TOPFOLD_BWD_CREEP_SPD	:=AdvPara[27];
CNST_APRON_BTMFOLD_FWD_SPD			:=AdvPara[28];
CNST_APRON_BTMFOLD_FWD_CREEP_SPD	:=AdvPara[29];
CNST_APRON_BTMFOLD_BWD_SPD			:=AdvPara[30];
CNST_APRON_BTMFOLD_BWD_CREEP_SPD	:=AdvPara[31];
CNST_APRON_TOPFOLD_FWD_DecDis_GT110	:=AdvPara[32];
CNST_APRON_TOPFOLD_FWD_DecDis_LE110	:=AdvPara[33];
CNST_APRON_TOPFOLD_BWD_DecDis		:=AdvPara[34];
CNST_APRON_BTMFOLD_FWD_DecDis_GT110	:=AdvPara[35];
CNST_APRON_BTMFOLD_FWD_DecDis_LE110	:=AdvPara[36];
