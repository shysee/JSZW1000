	CONST_APRON_BTMFOLD_LIMIT			:REAL	:=150.0;		(*下翻板折弯 -- 机械极限*)
	
	CONST_CLAMP_LIGHT_PRESSURE_SETPOINT	:REAL	:=7.0;		(*钳口压紧的压力值*)	
	CONST_CLAMP_HEAVY_PRESSURE_SETPOINT	:INT	:=100;
	CONST_CLAMP_POS_CALIBRATION	:INT	:=4;		(*CLAMP calibration 定义为认为闭合的位置*)
	CONST_CLAMP_POS_HALF	:INT	:=45;
	CONST_CLAMP_POS_LOW	:INT	:=3;
	CONST_CLAMP_SPEED_CREEP	:INT	:=500;
	CONST_CLAMP_SPEED_HIGH	:INT	:=4000;
	CONST_CLAMP_MAXCONVERT		:DINT	:=10000;			(*模拟量为32767时对应的值*)
	
	CONST_BACKGAUGE_SPEED_HIGH	:INT	:=200;
	CONST_BACKGAUGE_SPEED_LOW	:INT	:=50;
	CONST_BACKGAUGE_SPEED_CREEP	:INT	:=20;
	CONST_BACKGAUGE_POS_ZERO	:INT	:=0;
	CONST_BACKGAUGE_POS_NegPlus	:INT	:=-20;
	CONST_BACKGAUGE_POS_Window	:REAL	:=2.0;
	
	CONST_BACKGAUGE_ATTACH_PUSH		:REAL	:=0.0;		(*附加量-PUSH*)
	CONST_BACKGAUGE_ATTACH_GRIP		:REAL	:=10.0;		(*附加量-GRIP*)
	CONST_BACKGAUGE_ATTACH_OVERGRIP	:REAL	:=30.0;		(*附加量-OVERGRIP*)
	CONST_BACKGAUGE_ATTACH_BACK		:REAL	:=60.0;		(*附加量-BACK*)
	
	CONST_TABLE_SPEED_HIGH	:INT	:=300;
	CONST_TABLE_POS_MAX		:INT	:=800;
	CONST_TABLE_POS_MIN		:INT	:=0;
	
	CONST_FEED_SPEED_HIGH	:INT	:=800;
	CONST_FEED_SPEED_LOW	:INT	:=500;
	CONST_FEED_SPEED_CREEP	:INT	:=20;
	CONST_FEED_POS_ZERO	:INT	:=0;
	CONST_FEED_POS_NegPlus	:INT	:=-20;
	CONST_FEED_POS_Window	:REAL	:=2.0;
	CONST_FEED_POS_MAX		:INT	:=3900;
	CONST_FEED_POS_MIN		:INT	:=-450;
	
END_VAR

VAR_GLOBAL 
	CNST_HYD_IDLE_SPD					:REAL	:=0.0;	//	油泵待机速度
							
	CNST_APRON_TOPSLIDE_FWD_SPD			:REAL	:=0.0;	//	上翻板滑动，前进，工作速度
