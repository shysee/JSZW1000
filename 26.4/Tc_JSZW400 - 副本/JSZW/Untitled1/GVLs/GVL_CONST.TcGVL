	CNST_BACKGAUGE_SPEED_HIGH			:REAL	:=0.0;	//	后夹送速度_高速
	CNST_BACKGAUGE_SPEED_LOW			:REAL	:=0.0;	//	后夹送速度_低速
	CNST_BACKGAUGE_ATTACH_PUSH			:REAL	:=0.0;	//	后夹送位置附加值_推动
	CNST_BACKGAUGE_ATTACH_GRIP			:REAL	:=0.0;	//	后夹送位置附加值_浅夹
	CNST_BACKGAUGE_ATTACH_OVERGRIP		:REAL	:=0.0;	//	后夹送位置附加值_深夹
	CNST_BACKGAUGE_ATTACH_BACK			:REAL	:=0.0;	//	后夹送位置附加值_后退
							
	CNST_TABLE_SPEED_HIGH				:REAL	:=0.0;	//	桌板速度_高速
	CNST_TABLE_POS_MAX					:REAL	:=0.0;	//	桌板限定位置_最大值
	CNST_TABLE_POS_MIN					:REAL	:=0.0;	//	桌板限定位置_最小值
								
	CNST_SLITTER_FWD_SPD				:REAL	:=0.0;	//	纵切前进，工作速度
	CNST_SLITTER_FWD_CREEP_SPD			:REAL	:=0.0;	//	纵切前进，爬行速度
	CNST_SLITTER_BWD_SPD				:REAL	:=0.0;	//	纵切后退，工作速度
	CNST_SLITTER_BWD_CREEP_SPD			:REAL	:=0.0;	//	纵切后退，爬行速度
								
	CNST_ANGLE_LIMIT_HEAVY				:REAL	:=0.0;	//	最大限制角度 重型
	CNST_ANGLE_LIMIT_LIGHT				:REAL	:=0.0;	//	最大限制角度 轻型
								
	CNST_LUBE_HYP_COUNTS				:REAL	:=0.0;	//	润滑泵注油动作计数
	CNST_LUBE_DURATION_WORK				:REAL	:=0.0;	//	润滑泵注油持续时间
	
	CNST_FEED_SPEED_HIGH				:INT	:=200;
	CNST_FEED_SPEED_LOW					:INT	:=50;
	CNST_FEED_SPEED_CREEP				:INT	:=20;
	CNST_FEED_POS_ZERO					:INT	:=0;
	CNST_FEED_POS_NegPlus				:INT	:=-20;
	CNST_FEED_POS_Window				:REAL	:=2.0;
	CNST_FEED_POS_MAX					:INT	:=5000;
	CNST_FEED_POS_MIN					:INT	:=-1000;
	
