  <GVL Name="GVL_CONST" Id="{7d242ea1-2a14-4640-bbdd-3e8d7bf75777}">
    <Declaration><![CDATA[VAR_GLOBAL CONSTANT
	PUMP_FREQ_IDLE: USINT  :=143;
	
	
