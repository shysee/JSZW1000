	CNST_APRON_BTMFOLD_MIN				:REAL	:=0.0;	//	下翻板折弯，最小极限
	CNST_APRON_BTMFOLD_MAX				:REAL	:=0.0;	//	下翻板折弯，最大极限
						
	CNST_CLAMP_OPEN_SPD_LT_HALF			:REAL	:=0.0;	//	钳口打开速度，低于半钳口位（手动模式）
