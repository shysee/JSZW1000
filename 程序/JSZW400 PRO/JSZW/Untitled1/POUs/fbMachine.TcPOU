CNST_CLAMP_HEAVY_PRESSURE_SETPOINT	:=AdvPara[49];
CNST_CLAMP_POS_CLOSED				:=AdvPara[50];

CNST_BACKGAUGE_SPEED_HIGH			:=AdvPara[52];
CNST_BACKGAUGE_SPEED_LOW			:=AdvPara[53];
CNST_BACKGAUGE_ATTACH_PUSH			:=AdvPara[54];
CNST_BACKGAUGE_ATTACH_GRIP			:=AdvPara[55];
CNST_BACKGAUGE_ATTACH_OVERGRIP		:=AdvPara[56];
