CNST_APRON_BTMFOLD_MIN				:=AdvPara[41];
CNST_APRON_BTMFOLD_MAX				:=AdvPara[42];
	
CNST_CLAMP_OPEN_SPD_LT_HALF			:=AdvPara[44];
CNST_CLAMP_OPEN_SPD_GT_HALF			:=AdvPara[45];
CNST_CLAMP_CLOSE_SPD_LT_HALF		:=AdvPara[46];
CNST_CLAMP_CLOSE_SPD_GT_HALF		:=AdvPara[47];
