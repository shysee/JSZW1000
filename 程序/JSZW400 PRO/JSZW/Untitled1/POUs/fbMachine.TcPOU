CNST_ANGLE_LIMIT_HEAVY				:=AdvPara[68];
CNST_ANGLE_LIMIT_LIGHT				:=AdvPara[69];
	
CNST_LUBE_HYP_COUNTS				:=AdvPara[71];
CNST_LUBE_DURATION_WORK				:=AdvPara[72];

CNST_GRIP_AUTOOPEN_TIME				:=AdvPara[74];
GRIP_AUTOOPEN_TIME	:=REAL_TO_TIME(CNST_GRIP_AUTOOPEN_TIME);

CNST_TAPER_REF						:=AdvPara[76];

CNST_TAPER_REF_T1					:=CNST_TAPER_REF;
CNST_TAPER_REF_T2					:=CNST_TAPER_REF + 760;
CNST_TAPER_REF_T3					:=CNST_TAPER_REF + 1500;
CNST_TAPER_REF_T4					:=CNST_TAPER_REF + 2260;
]]></ST>
      </Implementation>
    </Action>
    <Action Name="A_DebugVar" Id="{bda1942d-277e-44ef-a138-97837cdcf184}">
      <Implementation>
        <ST><![CDATA[(*
bEnable	:=TRUE;
Hmi_iArray[0]	;


CASE iBootState OF
	0				:	
		ton1(IN:=TRUE , PT:=T#2S); 
		iBootSeq:=SEL(ton1.Q,0,1);
	1				:	eStateCommand := 8;ton1(IN:=TRUE , PT:=T#2S); iBootSeq:=SEL(ton1.Q,0,1);
	0				:	ton1(IN:=TRUE , PT:=T#2S); iBootSeq:=SEL(ton1.Q,0,1);
	0				:	ton1(IN:=TRUE , PT:=T#2S); iBootSeq:=SEL(ton1.Q,0,1);
