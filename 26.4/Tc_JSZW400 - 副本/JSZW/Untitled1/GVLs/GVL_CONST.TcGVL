	CNST_APRON_TOPFOLD_FWD_CREEP_SPD	:REAL	:=0.0;	//	上翻板折弯，前进，爬行速度
	CNST_APRON_TOPFOLD_BWD_SPD			:REAL	:=0.0;	//	上翻板折弯，后退，工作速度
	CNST_APRON_TOPFOLD_BWD_CREEP_SPD	:REAL	:=0.0;	//	上翻板折弯，后退，爬行速度
	CNST_APRON_BTMFOLD_FWD_SPD			:REAL	:=0.0;	//	下翻板折弯，前进，工作速度
	CNST_APRON_BTMFOLD_FWD_CREEP_SPD	:REAL	:=0.0;	//	下翻板折弯，前进，爬行速度
	CNST_APRON_BTMFOLD_BWD_SPD			:REAL	:=0.0;	//	下翻板折弯，后退，工作速度
	CNST_APRON_BTMFOLD_BWD_CREEP_SPD	:REAL	:=0.0;	//	下翻板折弯，后退，爬行速度
							
	CNST_APRON_TOPFOLD_FWD_DecDis_GT110	:REAL	:=0.0;	//	上翻板折弯，前进，>110度时，减速距离
	CNST_APRON_TOPFOLD_FWD_DecDis_LE110	:REAL	:=0.0;	//	上翻板折弯，后退，≤110度时，减速距离
	CNST_APRON_TOPFOLD_BWD_DecDis		:REAL	:=0.0;	//	上翻板折弯，后退，减速距离
	CNST_APRON_BTMFOLD_FWD_DecDis_GT110	:REAL	:=0.0;	//	下翻板折弯，前进，>110度时，减速距离
	CNST_APRON_BTMFOLD_FWD_DecDis_LE110	:REAL	:=0.0;	//	下翻板折弯，前进，≤110度时，减速距离
	CNST_APRON_BTMFOLD_BWD_DecDis		:REAL	:=0.0;	//	下翻板折弯，后退，减速距离
