      <LineId Id="3" Count="0" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetBreakOpen">
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetContactorOFF">
      <LineId Id="3" Count="0" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetContactorON">
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetStartLeft">
      <LineId Id="3" Count="1" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetStartRight">
      <LineId Id="3" Count="1" />
      <LineId Id="2" Count="0" />
    </LineIds>
    <LineIds Name="IOFcCom.SetStop">
      <LineId Id="2" Count="0" />
    </LineIds>
  </POU>
</TcPlcObject>