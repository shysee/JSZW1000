	CONST_APRON_TOPSLIDE_POS1		:REAL	:=50.0;
	CONST_APRON_TOPSLIDE_POS2		:REAL	:=100.0;
	CONST_APRON_TOPSLIDE_POS3		:REAL	:=195.0;		(*退回时为200*)

	CONST_APRON_BTMSLIDE_POS0		:REAL	:=0.0;			(*AtWork时为0*)
	CONST_APRON_BTMSLIDE_POS1		:REAL	:=50.0;
	CONST_APRON_BTMSLIDE_POS2		:REAL	:=100.0;
	CONST_APRON_BTMSLIDE_POS3		:REAL	:=195.0;		(*退回时为200*)

	
